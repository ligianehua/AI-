# ============ 应用 ============
APP_ENV=dev
# 生产必须替换为 ≥32 字节随机串（openssl rand -hex 32）；APP_ENV=prod 时保持默认值会拒绝启动
SECRET_KEY=dev-only-secret-key-change-me-in-production!
ACCESS_TOKEN_EXPIRE_MINUTES=720
# 生产必须加上前端实际访问域名，否则浏览器 CORS 预检失败（例：["https://sales.example.com"]）
CORS_ORIGINS=["http://localhost:3000"]

# ============ 数据库 / 缓存 ============
# 本机直连用 localhost；docker compose 内部已自动覆盖为 db/redis 服务名
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_sales
REDIS_URL=redis://localhost:6379/0
# 生产数据库密码（docker-compose.prod.yml 使用）。注意：避免 @ : / ? # 等 URL 保留字符，
# 否则拼入连接串会解析失败
POSTGRES_PASSWORD=change-me-in-production

# 异步任务模式：arq（Redis 队列 + worker，生产/docker）| local（进程内后台执行，无 Redis 开发用）
TASK_MODE=arq

# 风险提醒阈值（天）：商机无跟进 / 阶段停滞
RISK_STALE_DAYS=7
RISK_STUCK_DAYS=21

# ============ M0 引导管理员 ============
# M1 users 表上线后由数据库账号取代
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ============ LLM 供应商密钥（M2 起使用）============
# 密钥只放 .env，永不入库；模型注册表见 backend/app/ai/providers.yaml
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# 成本护栏：每用户每日 LLM token 限额（输入+输出），0 = 不限
LLM_DAILY_TOKEN_LIMIT_PER_USER=500000

# ============ 前端 ============
# 浏览器访问后端的地址。生产改为公网/域名地址（构建期内联进前端 bundle）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
