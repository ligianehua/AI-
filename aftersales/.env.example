# ===== 方式一：Anthropic 官方 API（优先级最高）=====
ANTHROPIC_API_KEY=

# ===== 方式二：OpenAI 兼容接口（中转站/国产模型：Qwen、GLM、DeepSeek 等）=====
OPENAI_API_KEY=
OPENAI_BASE_URL=
# 例：OPENAI_BASE_URL=https://api.silra.cn/v1  MODEL=qwen3-max
# 注意：所选模型需支持工具调用（function calling），已验证可用：qwen3-max、glm-5

# 模型（留空自动选择：Anthropic=claude-opus-4-8 / OpenAI兼容=qwen3-max）
MODEL=

# 演示模式：auto=无Key自动Mock / true=强制Mock / false=强制真实API
MOCK_MODE=auto

# 视觉/OCR 模型（OpenAI兼容模式下使用；默认 qwen-vl-max）
VISION_MODEL=
OCR_MODEL=

# 学习分析自动运行间隔（小时，默认6）
AUTO_ANALYZE_HOURS=

# 外部渠道 OpenAPI 密钥（微信网关/APP服务端接入；留空关闭）
CHANNEL_API_KEY=

# 数据库路径
DB_PATH=data/app.db

# 服务端口
PORT=8000
