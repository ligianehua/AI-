# 产品对比总结：matrix 为对齐矩阵；must_mention=输出全文须命中的参数值；must_note_partial=须指出仅部分产品有的参数
{"id": "pc-01", "input": {"matrix": {"products": [{"model_no": "VFD-750B", "name": "750W 变频器", "brand": "DeltaTech", "status": "active"}, {"model_no": "VFD-1500B", "name": "1.5kW 变频器", "brand": "DeltaTech", "status": "active"}], "rows": [{"param": "额定功率", "values": ["750W", "1.5kW"]}, {"param": "输入电压", "values": ["380V", "380V"]}, {"param": "防护等级", "values": ["IP20", "IP20"]}]}}, "expect": {"must_mention": ["750W", "1.5kW"]}}
{"id": "pc-02", "input": {"matrix": {"products": [{"model_no": "SG-2000", "name": "伺服电机", "brand": "SinoDrive", "status": "active"}, {"model_no": "SG-3000", "name": "伺服电机", "brand": "SinoDrive", "status": "active"}], "rows": [{"param": "额定转矩", "values": ["6.37N·m", "9.55N·m"]}, {"param": "编码器", "values": ["23bit", "—"]}]}}, "expect": {"must_mention": ["6.37", "9.55"], "must_note_partial": "编码器"}}
